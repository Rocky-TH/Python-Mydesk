{
    "name": "浅色主题",
    "description": "适合白天使用的浅色主题",
    "is_dark": false,
    
    "colors": {
        "primary": "#007acc",
        "primary-hover": "#005a9e",
        "primary-pressed": "#004575",
        
        "success": "#28a745",
        "warning": "#ffc107",
        "danger": "#dc3545",
        "info": "#17a2b8",
        
        "bg-main": "#f5f5f5",
        "bg-secondary": "#ffffff",
        "bg-tertiary": "#e8e8e8",
        "bg-input": "#ffffff",
        "bg-input-focus": "#f0f0f0",
        
        "border": "#d0d0d0",
        "border-light": "#e0e0e0",
        "border-focus": "#007acc",
        
        "text": "#333333",
        "text-secondary": "#666666",
        "text-hint": "#999999",
        "text-success": "#28a745",
        "text-warning": "#ffc107",
        "text-danger": "#dc3545",
        "text-info": "#17a2b8",
        
        "selection": "#007acc",
        "selection-text": "#ffffff"
    },
    
    "fonts": {
        "size-sm": "11px",
        "size-md": "12px",
        "size-lg": "13px",
        "size-xl": "14px",
        "size-xxl": "16px",
        "weight-normal": "500",
        "weight-bold": "bold"
    },
    
    "radius": {
        "sm": "4px",
        "md": "6px",
        "lg": "8px",
        "xl": "12px"
    },
    
    "components": {
        "button": {
            "bg": "@primary",
            "color": "#ffffff",
            "border": "none",
            "padding": "8px 16px",
            "radius": "@radius.md",
            "font-size": "@fonts.size-md",
            "font-weight": "@fonts.weight-bold",
            "hover-bg": "@primary-hover",
            "pressed-bg": "@primary-pressed"
        },
        
        "button-secondary": {
            "bg": "@bg-tertiary",
            "color": "@text",
            "border": "1px solid @border",
            "padding": "8px 16px",
            "radius": "@radius.md",
            "font-size": "@fonts.size-md",
            "font-weight": "@fonts.weight-bold",
            "hover-bg": "@bg-input-focus",
            "hover-border": "@border-focus",
            "pressed-bg": "@bg-secondary"
        },
        
        "input": {
            "bg": "@bg-input",
            "color": "@text",
            "border": "1px solid @border",
            "padding": "6px 10px",
            "radius": "@radius.sm",
            "font-size": "@fonts.size-md",
            "focus-bg": "@bg-input-focus",
            "focus-border": "@border-focus"
        },
        
        "combo-box": {
            "bg": "@bg-input",
            "color": "@text",
            "border": "1px solid @border",
            "padding": "6px 10px",
            "radius": "@radius.sm",
            "font-size": "@fonts.size-md",
            "popup-bg": "@bg-secondary",
            "popup-color": "@text",
            "popup-selection-bg": "@selection",
            "popup-selection-color": "@selection-text"
        },
        
        "text-edit": {
            "bg": "@bg-secondary",
            "color": "@text",
            "border": "1px solid @border",
            "padding": "8px",
            "radius": "@radius.sm",
            "font-family": "Consolas",
            "font-size": "@fonts.size-md"
        },
        
        "label": {
            "color": "@text",
            "font-size": "@fonts.size-md"
        },
        
        "label-secondary": {
            "color": "@text-secondary",
            "font-size": "@fonts.size-sm"
        },
        
        "menu": {
            "bg": "@bg-secondary",
            "color": "@text",
            "border": "1px solid @border",
            "radius": "@radius.md",
            "padding": "4px",
            "item-padding": "6px 24px",
            "item-selected-bg": "@primary",
            "item-selected-color": "#ffffff",
            "separator-bg": "@border-light",
            "separator-height": "1px"
        },
        
        "tab": {
            "bg": "@bg-tertiary",
            "color": "@text-secondary",
            "selected-bg": "@primary",
            "selected-color": "#ffffff",
            "hover-bg": "@bg-input",
            "hover-color": "@text",
            "border": "@border",
            "padding": "10px 24px",
            "font-size": "@fonts.size-md",
            "radius": "@radius.md"
        },
        
        "list": {
            "bg": "@bg-secondary",
            "color": "@text",
            "border": "1px solid @border",
            "radius": "@radius.sm",
            "font-size": "@fonts.size-md",
            "item-selected-bg": "@selection",
            "item-selected-color": "@selection-text",
            "item-hover-bg": "@bg-tertiary"
        },
        
        "group-box": {
            "color": "@text",
            "border": "2px solid @border",
            "radius": "@radius.lg",
            "bg": "@bg-secondary",
            "font-size": "@fonts.size-md",
            "font-weight": "@fonts.weight-bold"
        },
        
        "dialog": {
            "bg": "@bg-secondary",
            "color": "@text"
        },
        
        "scroll-bar": {
            "bg": "@bg-tertiary",
            "handle-bg": "@border",
            "handle-hover-bg": "@primary",
            "handle-radius": "@radius.sm"
        }
    }
}
