{
    "name": "QuicklyCmd",
    "display_name": "快捷命令",
    "version": "1.0.0",
    "description": "编译工具和字节转换工具",
    "toolbar": [],
    "menu": null,
    "compile": {
        "compile_environments": [
            {
                "name": "本地环境",
                "server": "localhost",
                "path": "/opt/build",
                "docker": null,
                "description": "本地编译环境",
                "connection": null
            },
            {
                "name": "开发服务器",
                "server": "192.168.1.100",
                "path": "/home/dev/build",
                "docker": "dev-container",
                "description": "开发环境编译服务器",
                "connection": {
                    "type": "ssh",
                    "host": "192.168.1.100",
                    "port": 22,
                    "username": "dev",
                    "password": "",
                    "key_file": ""
                }
            },
            {
                "name": "生产服务器",
                "server": "192.168.1.200",
                "path": "/home/prod/build",
                "docker": "prod-container",
                "description": "生产环境编译服务器",
                "connection": {
                    "type": "ssh",
                    "host": "192.168.1.200",
                    "port": 22,
                    "username": "prod",
                    "password": "",
                    "key_file": ""
                }
            },
            {
                "name": "Docker环境-A",
                "server": "localhost",
                "path": "/workspace/build",
                "docker": "build-env-a:latest",
                "description": "Docker编译环境A",
                "connection": null
            },
            {
                "name": "Docker环境-B",
                "server": "localhost",
                "path": "/workspace/build",
                "docker": "build-env-b:latest",
                "description": "Docker编译环境B",
                "connection": null
            },
            {
                "name": "串口设备",
                "server": "/dev/ttyUSB0",
                "path": "/flash",
                "docker": null,
                "description": "串口连接设备",
                "connection": {
                    "type": "serial",
                    "port": "/dev/ttyUSB0",
                    "baud": 115200,
                    "bytesize": 8,
                    "parity": "N",
                    "stopbits": 1
                }
            },
            {
                "name": "Telnet设备",
                "server": "192.168.1.101",
                "path": "/config",
                "docker": null,
                "description": "Telnet连接设备",
                "connection": {
                    "type": "telnet",
                    "host": "192.168.1.101",
                    "port": 23,
                    "username": "admin",
                    "password": ""
                }
            }
        ],
        "compile_components": [
            {
                "name": "全部组件",
                "targets": ["all"],
                "description": "编译所有组件"
            },
            {
                "name": "核心模块",
                "targets": ["core", "common"],
                "description": "编译核心模块"
            },
            {
                "name": "UI模块",
                "targets": ["ui", "widgets"],
                "description": "编译UI模块"
            },
            {
                "name": "网络模块",
                "targets": ["network", "protocol"],
                "description": "编译网络模块"
            },
            {
                "name": "工具模块",
                "targets": ["utils", "tools"],
                "description": "编译工具模块"
            }
        ],
        "test_environments": [
            {
                "name": "单元测试",
                "type": "unit",
                "command": "pytest tests/unit",
                "description": "运行单元测试"
            },
            {
                "name": "集成测试",
                "type": "integration",
                "command": "pytest tests/integration",
                "description": "运行集成测试"
            },
            {
                "name": "性能测试",
                "type": "performance",
                "command": "pytest tests/performance",
                "description": "运行性能测试"
            },
            {
                "name": "全部测试",
                "type": "all",
                "command": "pytest tests",
                "description": "运行所有测试"
            }
        ]
    }
}