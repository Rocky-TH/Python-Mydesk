{
    "name": "QuicklyCmd",
    "display_name": "快捷命令",
    "version": "1.0.0",
    "description": "编译工具和字节转换工具",
    "toolbar": [],
    "menu": null,
    "compile": {
        "environments": [
            {
                "name": "本地环境",
                "server": "localhost",
                "path": "/opt/build",
                "docker": null,
                "description": "本地编译环境"
            },
            {
                "name": "开发服务器",
                "server": "192.168.1.100",
                "path": "/home/dev/build",
                "docker": "dev-container",
                "description": "开发环境编译服务器"
            },
            {
                "name": "生产服务器",
                "server": "192.168.1.200",
                "path": "/home/prod/build",
                "docker": "prod-container",
                "description": "生产环境编译服务器"
            },
            {
                "name": "Docker环境-A",
                "server": "localhost",
                "path": "/workspace/build",
                "docker": "build-env-a:latest",
                "description": "Docker编译环境A"
            },
            {
                "name": "Docker环境-B",
                "server": "localhost",
                "path": "/workspace/build",
                "docker": "build-env-b:latest",
                "description": "Docker编译环境B"
            }
        ],
        "components": [
            {
                "name": "全部组件",
                "targets": ["all"],
                "description": "编译所有组件"
            },
            {
                "name": "核心模块",
                "targets": ["core", "common"],
                "description": "编译核心模块"
            },
            {
                "name": "UI模块",
                "targets": ["ui", "widgets"],
                "description": "编译UI模块"
            },
            {
                "name": "网络模块",
                "targets": ["network", "protocol"],
                "description": "编译网络模块"
            },
            {
                "name": "工具模块",
                "targets": ["utils", "tools"],
                "description": "编译工具模块"
            }
        ],
        "test_environments": [
            {
                "name": "单元测试",
                "type": "unit",
                "command": "pytest tests/unit",
                "description": "运行单元测试"
            },
            {
                "name": "集成测试",
                "type": "integration",
                "command": "pytest tests/integration",
                "description": "运行集成测试"
            },
            {
                "name": "性能测试",
                "type": "performance",
                "command": "pytest tests/performance",
                "description": "运行性能测试"
            },
            {
                "name": "全部测试",
                "type": "all",
                "command": "pytest tests",
                "description": "运行所有测试"
            }
        ]
    }
}