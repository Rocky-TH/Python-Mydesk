{
    "name": "MyDesk Style Config",
    "version": "1.0.0",
    "description": "统一的样式配置文件，修改此文件可调整整个软件的UI风格",
    
    "color_scheme": {
        "primary": "#007acc",
        "primary_hover": "#005a9e",
        "primary_pressed": "#004575",
        
        "success": "#28a745",
        "success_hover": "#218838",
        "warning": "#ffc107",
        "danger": "#dc3545",
        "info": "#17a2b8",
        
        "background_main": "#1e1e1e",
        "background_secondary": "#252526",
        "background_tertiary": "#2d2d30",
        "background_input": "#3c3c3c",
        "background_input_focus": "#4c4c4c",
        
        "border": "#3d3d40",
        "border_light": "#4a4a4d",
        "border_focus": "#007acc",
        
        "text_primary": "#ffffff",
        "text_secondary": "#cccccc",
        "text_hint": "#888888",
        "text_success": "#00ff00",
        "text_warning": "#ffff00",
        "text_danger": "#ff6b6b",
        "text_info": "#00d4ff",
        
        "selection": "#007acc",
        "selection_text": "#ffffff"
    },
    
    "font_sizes": {
        "small": "11px",
        "normal": "12px",
        "medium": "13px",
        "large": "14px",
        "extra_large": "16px"
    },
    
    "font_weights": {
        "normal": "500",
        "bold": "bold"
    },
    
    "border_radius": {
        "small": "4px",
        "normal": "6px",
        "large": "8px",
        "extra_large": "12px"
    },
    
    "components": {
        "main_window": {
            "background": "${color_scheme.background_main}"
        },
        
        "tab_widget": {
            "pane_border": "none",
            "pane_background": "${color_scheme.background_main}",
            "tab_background": "${color_scheme.background_tertiary}",
            "tab_color": "${color_scheme.text_secondary}",
            "tab_selected_background": "${color_scheme.primary}",
            "tab_selected_color": "${color_scheme.text_primary}",
            "tab_hover_background": "${color_scheme.background_input}",
            "tab_hover_color": "${color_scheme.text_primary}",
            "tab_border": "${color_scheme.border}",
            "tab_border_selected": "${color_scheme.primary}",
            "tab_padding": "10px 24px",
            "font_size": "${font_sizes.medium}",
            "font_weight": "${font_weights.normal}",
            "border_radius": "${border_radius.normal}"
        },
        
        "group_box": {
            "color": "${color_scheme.text_primary}",
            "font_size": "${font_sizes.medium}",
            "font_weight": "${font_weights.bold}",
            "border": "2px solid ${color_scheme.border_light}",
            "border_radius": "${border_radius.large}",
            "background": "${color_scheme.background_secondary}",
            "title_padding": "0 8px"
        },
        
        "button": {
            "background": "${color_scheme.primary}",
            "color": "${color_scheme.text_primary}",
            "border": "none",
            "font_size": "${font_sizes.medium}",
            "font_weight": "${font_weights.bold}",
            "border_radius": "${border_radius.normal}",
            "padding": "8px 16px",
            "hover_background": "${color_scheme.primary_hover}",
            "pressed_background": "${color_scheme.primary_pressed}"
        },
        
        "button_secondary": {
            "background": "${color_scheme.background_input}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border_light}",
            "font_size": "${font_sizes.medium}",
            "font_weight": "${font_weights.bold}",
            "border_radius": "${border_radius.normal}",
            "padding": "8px 16px",
            "hover_background": "${color_scheme.background_input_focus}",
            "hover_border": "${color_scheme.border_focus}",
            "pressed_background": "${color_scheme.background_tertiary}"
        },
        
        "line_edit": {
            "background": "${color_scheme.background_input}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border_light}",
            "border_radius": "${border_radius.small}",
            "padding": "6px 10px",
            "font_size": "${font_sizes.normal}",
            "focus_background": "${color_scheme.background_input_focus}",
            "focus_border": "${color_scheme.border_focus}"
        },
        
        "combo_box": {
            "background": "${color_scheme.background_input}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border_light}",
            "border_radius": "${border_radius.small}",
            "padding": "6px 10px",
            "font_size": "${font_sizes.normal}",
            "hover_background": "${color_scheme.background_input_focus}",
            "hover_border": "${color_scheme.border_focus}",
            "focus_background": "${color_scheme.background_input_focus}",
            "focus_border": "${color_scheme.border_focus}",
            "dropdown_border": "none",
            "dropdown_width": "20px",
            "arrow_color": "${color_scheme.text_secondary}",
            "popup_background": "${color_scheme.background_tertiary}",
            "popup_color": "${color_scheme.text_primary}",
            "popup_selection_background": "${color_scheme.selection}",
            "popup_selection_color": "${color_scheme.selection_text}",
            "popup_border": "1px solid ${color_scheme.border_light}",
            "popup_border_radius": "${border_radius.small}"
        },
        
        "plain_text_edit": {
            "background": "#0c0c0c",
            "color": "${color_scheme.text_success}",
            "border": "1px solid ${color_scheme.border}",
            "border_radius": "${border_radius.small}",
            "padding": "8px",
            "font_family": "Consolas",
            "font_size": "${font_sizes.normal}"
        },
        
        "text_edit": {
            "background": "${color_scheme.background_main}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border}",
            "border_radius": "${border_radius.small}",
            "margin": "4px",
            "focus_border": "2px solid ${color_scheme.border_focus}"
        },
        
        "label": {
            "color": "${color_scheme.text_primary}",
            "font_size": "${font_sizes.normal}",
            "font_weight": "${font_weights.normal}"
        },
        
        "label_secondary": {
            "color": "${color_scheme.text_secondary}",
            "font_size": "${font_sizes.small}",
            "font_weight": "${font_weights.normal}"
        },
        
        "label_success": {
            "color": "${color_scheme.text_success}",
            "font_size": "${font_sizes.normal}",
            "font_weight": "${font_weights.normal}"
        },
        
        "label_warning": {
            "color": "${color_scheme.text_warning}",
            "font_size": "${font_sizes.normal}",
            "font_weight": "${font_weights.bold}"
        },
        
        "label_danger": {
            "color": "${color_scheme.text_danger}",
            "font_size": "${font_sizes.normal}",
            "font_weight": "${font_weights.bold}"
        },
        
        "dialog": {
            "background": "${color_scheme.background_secondary}",
            "color": "${color_scheme.text_primary}"
        },
        
        "status_bar": {
            "background": "${color_scheme.primary}",
            "color": "${color_scheme.text_primary}"
        },
        
        "menu_bar": {
            "background": "${color_scheme.background_tertiary}",
            "color": "${color_scheme.text_primary}",
            "border_bottom": "1px solid ${color_scheme.border}",
            "padding": "2px",
            "item_selected_background": "${color_scheme.primary}",
            "item_border_radius": "${border_radius.small}",
            "item_padding": "4px 8px"
        },
        
        "menu": {
            "background": "${color_scheme.background_tertiary}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border_light}",
            "border_radius": "${border_radius.normal}",
            "padding": "4px",
            "item_selected_background": "${color_scheme.primary}",
            "item_border_radius": "${border_radius.small}",
            "item_padding": "4px 20px",
            "separator_height": "1px",
            "separator_background": "${color_scheme.border_light}",
            "separator_margin": "4px 8px"
        },
        
        "tool_bar": {
            "background": "${color_scheme.background_tertiary}",
            "border": "none",
            "spacing": "6px",
            "padding": "4px",
            "separator_color": "${color_scheme.border_light}",
            "separator_width": "1px",
            "separator_margin": "4px 8px"
        },
        
        "tool_button": {
            "background": "transparent",
            "border": "1px solid transparent",
            "border_radius": "${border_radius.small}",
            "padding": "6px 12px",
            "color": "${color_scheme.text_primary}",
            "font_size": "${font_sizes.normal}",
            "hover_background": "${color_scheme.background_input}",
            "hover_border": "${color_scheme.border_light}",
            "pressed_background": "${color_scheme.primary}",
            "pressed_border": "${color_scheme.primary}"
        },
        
        "list_widget": {
            "background": "${color_scheme.background_main}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border}",
            "border_radius": "${border_radius.small}",
            "font_size": "${font_sizes.normal}",
            "item_selected_background": "${color_scheme.selection}",
            "item_selected_color": "${color_scheme.selection_text}",
            "item_hover_background": "${color_scheme.background_tertiary}"
        },
        
        "spin_box": {
            "background": "${color_scheme.background_input}",
            "color": "${color_scheme.text_primary}",
            "border": "1px solid ${color_scheme.border_light}",
            "border_radius": "${border_radius.small}",
            "padding": "6px 10px",
            "font_size": "${font_sizes.normal}",
            "focus_background": "${color_scheme.background_input_focus}",
            "focus_border": "${color_scheme.border_focus}"
        },
        
        "scroll_bar": {
            "background": "${color_scheme.background_tertiary}",
            "handle_background": "${color_scheme.border_light}",
            "handle_border_radius": "${border_radius.small}",
            "handle_hover_background": "${color_scheme.primary}"
        }
    }
}